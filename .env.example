SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# SQLite (default for development)
DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (uncomment for production)
# DATABASE_URL=postgres://user:password@localhost:5432/tally_pro_db

# ── OCR Settings ─────────────────────────────────────────────────────────────
# Path to Tesseract executable (Windows default)
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# Path to Poppler bin folder (Windows — extract ZIP from GitHub releases)
# e.g. if you extracted to C:\poppler, this should be:
POPPLER_PATH=C:\poppler\Library\bin
