# ─────────────────────────────────────────────────────────────────────────────
# .env.docker.example  —  Copy to .env.docker and fill in your values
# This file is used by docker-compose (env_file: .env.docker)
# NEVER commit .env.docker to version control
# ─────────────────────────────────────────────────────────────────────────────

# Django core
SECRET_KEY=replace-this-with-a-50-char-random-string-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# PostgreSQL — must match the db service in docker-compose.yml
DATABASE_URL=postgres://tally_user:your_strong_password@db:5432/tally_pro_db

POSTGRES_DB=tally_pro_db
POSTGRES_USER=tally_user
POSTGRES_PASSWORD=your_strong_password

# Django security (production)
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# OCR — in Docker, Tesseract/Poppler are installed via apt; leave these blank
# (the code auto-detects Linux paths)
TESSERACT_PATH=
POPPLER_PATH=

# Email (optional — for future notifications)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your@email.com
# EMAIL_HOST_PASSWORD=your_app_password
# DEFAULT_FROM_EMAIL=TallyPro <your@email.com>
